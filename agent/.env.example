# Nicolas Agent System — environment variables
# Copy this file to `.env` (gitignored) and fill in real values.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED — Google Gemini API key
# ---------------------------------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey (no credit card required).
# `GOOGLE_API_KEY` is also accepted as a fallback name.
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# OPTIONAL — model override
# ---------------------------------------------------------------------------
# Default is set in agent/base_agent.py (DEFAULT_MODEL = "gemini-2.5-flash").
# To override per-agent, add a `model:` field in the agent's YAML file.
# Recommended models:
#   gemini-2.5-flash      (default — good quality / cost balance, generous free tier)
#   gemini-2.5-pro        (highest quality, for arbitrator on high-value disputes)
#   gemini-2.5-flash-lite (cheapest / fastest, for high-volume customer_service)

# ---------------------------------------------------------------------------
# OPTIONAL — generation parameters
# ---------------------------------------------------------------------------
# Override per-agent with `max_tokens:` in the YAML file.
# AGENT_MAX_TOKENS=1024

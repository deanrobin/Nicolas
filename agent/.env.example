# Nicolas Agent System — environment variables
# Copy this file to `.env` (gitignored) and fill in real values.
#   cp .env.example .env

# ===========================================================================
# CLI agents (main.py) + Auditor worker (python -m worker)
# ===========================================================================

# REQUIRED — Google Gemini API key
# Get a free key at https://aistudio.google.com/apikey (no credit card).
# `GOOGLE_API_KEY` is also accepted as a fallback name.
GEMINI_API_KEY=your-gemini-api-key-here

# OPTIONAL — model override
# Default is set in agent/base_agent.py (DEFAULT_MODEL = "gemini-2.5-flash").
# To override per-agent, add a `model:` field in the agent's YAML file.
# Recommended models:
#   gemini-2.5-flash      (default)
#   gemini-2.5-pro        (for arbitrator on high-value disputes)
#   gemini-2.5-flash-lite (for high-volume customer_service)


# ===========================================================================
# Auditor worker only (python -m worker)
# ===========================================================================

# MySQL connection — points at the same DB the Java backend uses.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=nicolas

# Polling interval in seconds. Worker scans the three auditable tables
# (merchants, agent_listings, skill_listings) every cycle.
POLL_INTERVAL_SEC=60

# Feishu (Lark) custom-bot webhook URL. Worker posts every verdict here.
# Leave empty to disable Feishu notifications.
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token-here

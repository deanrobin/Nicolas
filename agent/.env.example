# Nicolas Agent System — environment variables
# Copy this file to `.env` (gitignored) and fill in real values.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED — Anthropic API key for Claude
# ---------------------------------------------------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# OPTIONAL — model override
# ---------------------------------------------------------------------------
# Default is set in agent/base_agent.py (DEFAULT_MODEL).
# To override per-agent, add a `model:` field in the agent's YAML file.
# Recommended models:
#   claude-sonnet-4-6   (default — good quality / cost balance)
#   claude-opus-4-7     (highest quality, for arbitrator on high-value disputes)
#   claude-haiku-4-5    (cheapest / fastest, for high-volume customer_service)

# ---------------------------------------------------------------------------
# OPTIONAL — generation parameters
# ---------------------------------------------------------------------------
# Override per-agent with `max_tokens:` in the YAML file.
# AGENT_MAX_TOKENS=1024

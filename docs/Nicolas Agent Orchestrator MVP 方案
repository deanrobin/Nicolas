    -- APPROVE / REJECT / MANUAL_REVIEW

    agent_risk_level VARCHAR(32) NOT NULL,
    -- LOW / MEDIUM / HIGH

    agent_result_json JSON NOT NULL,

    status VARCHAR(32) NOT NULL,
    -- WAITING_HUMAN / HUMAN_APPROVED / HUMAN_REJECTED /
    -- AUTO_APPROVED / AUTO_REJECTED / NEED_CHANGE / EXPIRED_MANUAL_REVIEW

    auto_apply_enabled BOOLEAN NOT NULL DEFAULT TRUE,
    auto_apply_at DATETIME NULL,

    human_reviewer_id BIGINT NULL,
    human_decision VARCHAR(32) NULL,
    human_comment TEXT NULL,
    reviewed_at DATETIME NULL,

    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,

    INDEX idx_review_cases_status (status),
    INDEX idx_review_cases_auto_apply (auto_apply_enabled, auto_apply_at),
    INDEX idx_review_cases_subject (subject_type, subject_id)
);
```

审核结果写入逻辑：

```text
agent_decision = APPROVE
  → status = WAITING_HUMAN
  → auto_apply_enabled = true
  → auto_apply_at = now + 24h

agent_decision = REJECT
  → status = WAITING_HUMAN
  → auto_apply_enabled = true
  → auto_apply_at = now + 24h

agent_decision = MANUAL_REVIEW
  → status = WAITING_HUMAN
  → auto_apply_enabled = false
  → auto_apply_at = null
```

